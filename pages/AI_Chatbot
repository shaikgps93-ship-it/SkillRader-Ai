
import streamlit as st

# ---------------- PAGE CONFIG ----------------
st.set_page_config(
    page_title="SkillRadar AI Chatbot",
    page_icon="🤖",
    layout="wide"
)

# ---------------- HOME BUTTON ----------------
top1, top2 = st.columns([8, 1])

with top2:
    if st.button("🏠 Home"):
        st.switch_page("app.py")

# ---------------- HEADER ----------------
st.title("🤖 SkillRadar AI Assistant")
st.caption("Ask career questions and get guidance")

# Initialize chat history
if "messages" not in st.session_state:
    st.session_state.messages = []

# Show previous messages
for message in st.session_state.messages:

    with st.chat_message(message["role"]):
        st.markdown(message["content"])

# User input
prompt = st.chat_input(
    "Ask me anything about careers..."
)

if prompt:

    # Save user message
    st.session_state.messages.append(
        {
            "role": "user",
            "content": prompt
        }
    )

    with st.chat_message("user"):
        st.markdown(prompt)

    response = ""

    question = prompt.lower()

    # Simple AI responses
    if "python" in question:
        response = """
Python is one of the most valuable skills for:

- Data Analyst
- Data Engineer
- Data Scientist

Recommended next step:
Learn Pandas + SQL + Projects.
"""

    elif "salary" in question:
        response = """
Typical salary ranges:

Data Analyst → ₹5–8 LPA
BI Analyst → ₹7–10 LPA
Data Engineer → ₹10–15 LPA
Data Scientist → ₹12–20 LPA
"""

    elif "roadmap" in question:
        response = """
Recommended roadmap:

1. Excel
2. SQL
3. Power BI
4. Python
5. Projects
6. Interviews
"""

    elif "data engineer" in question:
        response = """
Data Engineer Roadmap:

• Python
• Pandas
• SQL
• AWS
• ETL Concepts
• Spark
"""

    else:
        response = """
I can help with:

• Career Roadmaps
• Salary Guidance
• Skills to Learn
• Data Analyst Career
• Data Engineer Career
"""

    # Save assistant response
    st.session_state.messages.append(
        {
            "role": "assistant",
            "content": response
        }
    )

    with st.chat_message("assistant"):
        st.markdown(response)
